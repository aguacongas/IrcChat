@page "/"
@page "/login"
@using IrcChat.Client.Extensions
@using IrcChat.Shared.Models
@using IrcChat.Client.Services
@inject HttpClient Http
@inject IUnifiedAuthService Auth
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Connexion - IRC Chat</PageTitle>

@if (!isInitialized)
{
    <div class="login-fullscreen">
        <div class="login-card">
            <div class="loading-message">
                <div class="spinner"></div>
                <span>Chargement...</span>
            </div>
        </div>
    </div>
}
else if (isAgeBlocked)
{
    <div class="login-fullscreen">
        <div class="login-card">
            <div class="age-blocked-message">
                <div class="blocked-icon">⚠️</div>
                <h2>Âge insuffisant</h2>
                <p>Tu dois avoir au moins 13 ans pour utiliser ce service.</p>
                <button class="btn-secondary" @onclick="ResetAgeBlock">
                    ← Retour
                </button>
            </div>
        </div>
    </div>
}
else
{
    <div class="login-fullscreen">
        <div class="login-card">
            <div class="login-header">
                <h1>💬 IRC Chat</h1>
                <h2>Bienvenue</h2>
                <p>Entrez votre pseudo pour commencer</p>
            </div>

            <div class="username-form">
                <input value="@username"
                       @oninput="OnUsernameInput"
                       placeholder="Votre pseudo..."
                       maxlength="20"
                       @onkeypress="HandleKeyPress"
                       disabled="@(Auth.IsReserved && !Auth.IsAuthenticated)"
                       autofocus />

                @if (isChecking)
                {
                    <div class="checking">
                        <div class="spinner-small"></div>
                        <span>Vérification...</span>
                    </div>
                }
                else if (usernameStatus != null)
                {
                    @if (usernameStatus.IsReserved && usernameStatus.ReservedProvider.HasValue)
                    {
                        <div class="status reserved">
                            <span>🔒</span> Ce pseudo est réservé
                        </div>
                        <button class="btn-primary" @onclick="() => LoginWithProvider(usernameStatus.ReservedProvider.Value)">
                            Se connecter
                        </button>
                    }
                    else if (usernameStatus.IsCurrentlyUsed)
                    {
                        <div class="status unavailable">
                            <span>⚠️</span> Ce pseudo est actuellement utilisé
                        </div>
                    }
                    else if (usernameStatus.Available)
                    {
                        <div class="dob-section">
                            <label>Date de naissance</label>
                            <div class="dob-dropdowns">
                                <select id="day" @bind="selectedDay">
                                    <option value="0">Jour</option>
                                    @for (int i = 1; i <= 31; i++)
                                    {
                                        <option value="@i">@i</option>
                                    }
                                </select>

                                <select id="month" @bind="selectedMonth">
                                    <option value="0">Mois</option>
                                    @for (int i = 1; i <= 12; i++)
                                    {
                                        <option value="@i">@i</option>
                                    }
                                </select>

                                <select id="year" @bind="selectedYear">
                                    <option value="0">Année</option>
                                    @for (int i = DateTime.UtcNow.Year; i >= DateTime.UtcNow.Year - 120; i--)
                                    {
                                        <option value="@i">@i</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="status-actions">
                            <button class="btn-primary" @onclick="EnterAsGuest">
                                Entrer en tant qu'invité
                            </button>
                            <button class="btn-secondary" @onclick="NavigateToReserve">
                                🔒 Réserver ce pseudo
                            </button>
                        </div>
                    }
                }
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-message">
                    <span>⚠️</span> @errorMessage
                </div>
            }

            @if (Auth.HasUsername && !string.IsNullOrEmpty(Auth.Username))
            {
                <div class="saved-username">
                    <p>Pseudo mémorisé: <strong>@Auth.Username</strong></p>
                    @if (Auth.IsReserved)
                    {
                        <span class="badge-reserved">🔒 Réservé</span>

                        @if (!Auth.IsAuthenticated)
                        {
                            <button class="btn-link" @onclick="UseAnotherUsername">
                                Utiliser un autre pseudo
                            </button>
                        }
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private string username = string.Empty;
    private string errorMessage = string.Empty;
    private bool isInitialized = false;
    private bool isChecking = false;
    private bool isAgeBlocked = false;
    private UsernameCheckResponse? usernameStatus = null;
    private System.Threading.Timer? _debounceTimer;

    private int selectedDay = 0;
    private int selectedMonth = 0;
    private int selectedYear = 0;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        isInitialized = true;

        if (Auth.IsAuthenticated)
        {
            Navigation.NavigateToRelative("chat");
            return;
        }

        if (Auth.HasUsername)
        {
            username = Auth.Username ?? string.Empty;
            await CheckUsername();
        }

        if (Auth.DateOfBirth.HasValue)
        {
            var dob = Auth.DateOfBirth.Value;
            selectedDay = dob.Day;
            selectedMonth = dob.Month;
            selectedYear = dob.Year;
        }
    }

    private void OnUsernameInput(ChangeEventArgs e)
    {
        username = e.Value?.ToString() ?? string.Empty;
        usernameStatus = null;
        errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(username) || username.Length < 3)
        {
            return;
        }

        _debounceTimer?.Dispose();
        _debounceTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(CheckUsername);
        }, null, 500, System.Threading.Timeout.Infinite);
    }

    private async Task CheckUsername()
    {
        if (string.IsNullOrWhiteSpace(username) || username.Length < 3)
        {
            return;
        }

        isChecking = true;
        StateHasChanged();

        try
        {
            var request = new UsernameCheckRequest { Username = username.Trim() };
            var response = await Http.PostAsJsonAsync("/api/oauth/check-username", request);
            response.EnsureSuccessStatusCode();
            usernameStatus = await response.Content.ReadFromJsonAsync<UsernameCheckResponse>();
        }
        catch
        {
            errorMessage = "Erreur lors de la vérification";
        }
        finally
        {
            isChecking = false;
            StateHasChanged();
        }
    }

    private async Task EnterAsGuest()
    {
        var cleanUsername = username.Trim();
        if (cleanUsername.Length < 3)
        {
            errorMessage = "Le pseudo doit contenir au moins 3 caractères";
            return;
        }

        if (selectedDay == 0 || selectedMonth == 0 || selectedYear == 0)
        {
            errorMessage = "Veuillez sélectionner votre date de naissance complète";
            return;
        }

        try
        {
            var dateOfBirth = new DateTime(selectedYear, selectedMonth, selectedDay, 0, 0, 0, DateTimeKind.Utc);

            if (!IsValidAge(dateOfBirth))
            {
                return;
            }

            await Auth.SetDateOfBirthAsync(dateOfBirth);
            await Auth.SetUsernameAsync(cleanUsername, isReserved: false);
            Navigation.NavigateToRelative("chat");
        }
        catch (ArgumentOutOfRangeException)
        {
            errorMessage = "La date saisie n'est pas valide (exemple: 31 février n'existe pas)";
        }
    }

    private bool IsValidAge(DateTime dateOfBirth)
    {
        var age = CalculateAge(dateOfBirth);

        if (age < 13)
        {
            isAgeBlocked = true;
            StateHasChanged();
            return false;
        }

        if (age > 120)
        {
            errorMessage = "La date de naissance saisie n'est pas valide.";
            return false;
        }

        return true;
    }

    private static int CalculateAge(DateTime dateOfBirth)
    {
        var today = DateTime.UtcNow;
        var age = today.Year - dateOfBirth.Year;

        if (dateOfBirth.Date > today.AddYears(-age))
        {
            age--;
        }

        return age;
    }

    private void ResetAgeBlock()
    {
        isAgeBlocked = false;
        selectedDay = 0;
        selectedMonth = 0;
        selectedYear = 0;
        errorMessage = string.Empty;
        StateHasChanged();
    }

    private async Task LoginWithProvider(ExternalAuthProvider provider)
    {
        await JS.InvokeVoidAsync("sessionStorage.setItem", "temp_username_for_login", username);
        Navigation.NavigateToRelative($"oauth-login?provider={provider}&mode=login");
    }

    private async Task UseAnotherUsername()
    {
        await Auth.ClearAllAsync();
        username = string.Empty;
        usernameStatus = null;
        errorMessage = string.Empty;
        selectedDay = 0;
        selectedMonth = 0;
        selectedYear = 0;
        StateHasChanged();
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && usernameStatus?.Available == true)
        {
            await EnterAsGuest();
        }
    }

    private void NavigateToReserve()
    {
        if (selectedDay == 0 || selectedMonth == 0 || selectedYear == 0)
        {
            errorMessage = "Veuillez sélectionner votre date de naissance avant de réserver";
            return;
        }

        try
        {
            var dateOfBirth = new DateTime(selectedYear, selectedMonth, selectedDay, 0, 0, 0, DateTimeKind.Utc);

            if (!IsValidAge(dateOfBirth))
            {
                return;
            }

            var url = $"reserve?username={Uri.EscapeDataString(username)}&day={selectedDay}&month={selectedMonth}&year={selectedYear}";
            Navigation.NavigateToRelative(url);
        }
        catch (ArgumentOutOfRangeException)
        {
            errorMessage = "La date saisie n'est pas valide (exemple: 31 février n'existe pas)";
        }
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }
}
