@page "/settings"
@using IrcChat.Client.Extensions
@using IrcChat.Shared.Models
@using IrcChat.Client.Services
@using IrcChat.Client.Components
@inject HttpClient Http
@inject IUnifiedAuthService Auth
@inject IChatService ChatService
@inject IActiveChannelsService ActiveChannels
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<Settings> Logger

<PageTitle>Paramètres - IRC Chat</PageTitle>

@if (!isInitialized)
{
    <div class="loading-fullscreen">
        <div class="spinner"></div>
        <p>Chargement...</p>
    </div>
}
else if (!Auth.HasUsername)
{
    <p>Redirection...</p>
}
else
{
    <div class="settings-page">
        <div class="settings-header">
            <button class="back-button" @onclick="GoBack">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Retour
            </button>
            <h1>Paramètres</h1>
        </div>

        <div class="settings-container">
            <!-- Section Profil -->
            <div class="settings-card">
                <div class="card-header">
                    <h2>👤 Profil</h2>
                </div>
                <div class="card-content">
                    <div class="profile-section">
                        @if (!string.IsNullOrEmpty(Auth.AvatarUrl))
                        {
                            <img src="@Auth.AvatarUrl" alt="Avatar" class="profile-avatar" />
                        }
                        else
                        {
                            <div class="avatar-placeholder">👤</div>
                        }
                        <div class="profile-info">
                            <h3>@Auth.Username</h3>
                            @if (Auth.IsReserved)
                            {
                                <div class="profile-badges">
                                    <span class="badge badge-verified">✓ Pseudo réservé</span>
                                    @if (Auth.IsAdmin)
                                    {
                                        <span class="badge badge-admin">⚡ Administrateur</span>
                                    }
                                </div>
                                <p class="profile-email">@Auth.Email</p>
                                <p class="profile-provider">Connecté via @Auth.ReservedProvider</p>
                            }
                            else
                            {
                                <span class="badge badge-guest">Invité</span>
                                <p class="profile-hint">Votre pseudo n'est pas protégé</p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section Mode non MP -->
            <div class="settings-card">
                <div class="card-header">
                    <h2>🔒 Mode non MP</h2>
                </div>
                <div class="card-content">
                    <div class="setting-item">
                        <div class="setting-info">
                            <h3>Bloquer les messages privés non sollicités</h3>
                            <p>Vous ne recevrez des messages privés que des utilisateurs avec qui vous avez déjà une conversation active.</p>
                        </div>
                        <button class="toggle @(Auth.IsNoPvMode ? "active" : "")"
                                @onclick="ToggleNoPvMode"
                                aria-label="@(Auth.IsNoPvMode ? "Désactiver le mode non MP" : "Activer le mode non MP")">
                            <span class="toggle-text">@(Auth.IsNoPvMode ? "Activé" : "Désactivé")</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Section Admin -->
            @if (Auth.IsAdmin && Auth.UserId.HasValue)
            {
                <div class="settings-card card-admin">
                    <div class="card-header">
                        <h2>⚡ Administration</h2>
                    </div>
                    <div class="card-content">
                        <p class="card-description">Gérez les utilisateurs et leurs permissions</p>
                        <button class="btn btn-admin" @onclick="OpenAdminPanel">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 15a3 3 0 100-6 3 3 0 000 6z" />
                                <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z" />
                            </svg>
                            Ouvrir le panneau d'administration
                        </button>
                    </div>
                </div>
            }

            <!-- Section Gestion des salons -->
            @if (Auth.IsReserved && Auth.IsAuthenticated)
            {
                <div class="settings-card">
                    <div class="card-header">
                        <h2>🏠 Gestion des salons</h2>
                    </div>
                    <div class="card-content">
                        <p class="card-description">Créez vos propres salons de discussion</p>
                        <div class="channel-form">
                            <div class="form-group">
                                <label for="channel-name">Nom du salon</label>
                                <input id="channel-name"
                                       @bind="newChannelName"
                                       @bind:event="oninput"
                                       placeholder="general, support, random..."
                                       maxlength="20"
                                       @onkeyup="HandleChannelKeyPress"
                                       class="input-text" />
                            </div>
                            <div class="form-group">
                                <label for="channel-description">Description (optionnelle)</label>
                                <textarea id="channel-description"
                                          @bind="newChannelDescription"
                                          @bind:event="oninput"
                                          placeholder="Décrivez le sujet de ce salon..."
                                          maxlength="200"
                                          rows="3"
                                          class="input-textarea"></textarea>
                                <div class="char-counter">@(newChannelDescription?.Length ?? 0) / 200</div>
                            </div>
                            <div class="form-group">
                                <label for="channel-minimum-age">Âge minimum (0 = aucune restriction)</label>
                                <input id="channel-minimum-age"
                                       type="number"
                                       @bind="newChannelMinimumAge"
                                       @bind:event="oninput"
                                       min="0"
                                       class="input-text input-number" />
                            </div>
                            <button @onclick="CreateChannel"
                                    disabled="@string.IsNullOrWhiteSpace(newChannelName)"
                                    class="btn btn-primary btn-create">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <line x1="12" y1="5" x2="12" y2="19"></line>
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                </svg>
                                Créer le salon
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(channelMessage))
                        {
                            <div class="alert @(channelError ? "alert-error" : "alert-success")">
                                @channelMessage
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Section Compte -->
            <div class="settings-card card-danger">
                <div class="card-header">
                    <h2>⚠️ Gestion du compte</h2>
                </div>
                <div class="card-content">
                    @if (Auth.IsReserved)
                    {
                        <div class="danger-zone">
                            <h3>Oublier ce pseudo</h3>
                            <p>Cette action supprimera définitivement la réservation de votre pseudo. Vous serez déconnecté et ne pourrez plus utiliser ce pseudo réservé.</p>
                            <button @onclick="ShowForgetConfirmation" class="btn btn-danger">
                                Oublier mon pseudo
                            </button>
                        </div>
                        <div class="logout-zone">
                            <button @onclick="Logout" class="btn btn-secondary">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                    <polyline points="16 17 21 12 16 7" />
                                    <line x1="21" y1="12" x2="9" y2="12" />
                                </svg>
                                Se déconnecter
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="info-zone">
                            <p>En tant qu'invité, vous pouvez réserver votre pseudo pour le protéger.</p>
                            <button @onclick="GoToReserve" class="btn btn-primary">
                                Réserver mon pseudo
                            </button>
                        </div>
                        <div class="logout-zone">
                            <button @onclick="Logout" class="btn btn-secondary">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                    <polyline points="16 17 21 12 16 7" />
                                    <line x1="21" y1="12" x2="9" y2="12" />
                                </svg>
                                Se déconnecter
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (showForgetModal)
    {
        <div class="modal-overlay" @onclick="HideForgetConfirmation">
            <div class="modal-box" @onclick:stopPropagation="true">
                <h2>⚠️ Confirmer la suppression</h2>
                <p>Êtes-vous sûr de vouloir oublier le pseudo <strong>@Auth.Username</strong> ?</p>
                <p class="modal-warning">Cette action est irréversible. Vous perdrez définitivement la réservation de ce pseudo.</p>
                <div class="modal-actions">
                    <button @onclick="HideForgetConfirmation" class="btn btn-secondary">
                        Annuler
                    </button>
                    <button @onclick="ConfirmForget" class="btn btn-danger">
                        Oui, oublier ce pseudo
                    </button>
                </div>
            </div>
        </div>
    }

    @if (showAdminPanel && Auth.IsAdmin && Auth.UserId.HasValue)
    {
        <AdminPanel CurrentUserId="@Auth.UserId.Value"
                    OnClose="CloseAdminPanel" />
    }
}

@code {
    private bool isInitialized = false;
    private string newChannelName = string.Empty;
    private string newChannelDescription = string.Empty;
    private int newChannelMinimumAge = 0;
    private string channelMessage = string.Empty;
    private bool channelError = false;
    private bool showForgetModal = false;
    private bool showAdminPanel = false;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        isInitialized = true;

        if (!Auth.HasUsername)
        {
            Navigation.NavigateToRelative("login");
        }
    }

    private void GoBack()
    {
        Navigation.NavigateToRelative("chat");
    }

    private void GoToReserve()
    {
        Navigation.NavigateToRelative($"reserve?username={Uri.EscapeDataString(Auth.Username ?? string.Empty)}");
    }

    private void OpenAdminPanel()
    {
        showAdminPanel = true;
    }

    private void CloseAdminPanel()
    {
        showAdminPanel = false;
    }

    private async Task ToggleNoPvMode()
    {
        await Auth.SetNoPvModeAsync(!Auth.IsNoPvMode);
        StateHasChanged();
    }

    private async Task CreateChannel()
    {
        if (string.IsNullOrWhiteSpace(newChannelName))
        {
            return;
        }

        channelMessage = string.Empty;
        channelError = false;

        var channel = new Channel
        {
            Name = newChannelName.Trim(),
            Description = string.IsNullOrWhiteSpace(newChannelDescription)
                ? null
                : newChannelDescription.Trim(),
            CreatedBy = Auth.Username ?? string.Empty,
            MinimumAge = newChannelMinimumAge < 0 ? 0 : newChannelMinimumAge,
        };

        try
        {
            var response = await Http.PostAsJsonAsync("/api/channels", channel);

            if (response.IsSuccessStatusCode)
            {
                var createdChannel = await response.Content.ReadFromJsonAsync<Channel>();
                channelMessage = $"✓ Le salon #{newChannelName} a été créé avec succès !";
                channelError = false;

                var channelToJoin = createdChannel?.Name ?? newChannelName.Trim();
                newChannelName = string.Empty;
                newChannelDescription = string.Empty;
                newChannelMinimumAge = 0;

                await Task.Delay(500);
                Navigation.NavigateToRelative($"chat/channel/{Uri.EscapeDataString(channelToJoin)}");
                return;
            }

            var errorContent = await response.Content.ReadAsStringAsync();
            if (errorContent.Contains("channel_exists"))
            {
                channelMessage = "✗ Ce salon existe déjà";
            }
            else if (errorContent.Contains("missing_channel_name"))
            {
                channelMessage = "✗ Le nom du salon est requis";
            }
            else if (errorContent.Contains("invalid_minimum_age"))
            {
                channelMessage = "✗ L'âge minimum ne peut pas être négatif";
            }
            else
            {
                channelMessage = "✗ Erreur lors de la création du salon";
            }
            channelError = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Erreur lors de la création du salon {ChannelName}", newChannelName);
            channelMessage = "✗ Erreur de connexion";
            channelError = true;
        }
    }

    private async Task HandleChannelKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await CreateChannel();
        }
    }

    private void ShowForgetConfirmation()
    {
        showForgetModal = true;
    }

    private void HideForgetConfirmation()
    {
        showForgetModal = false;
    }

    private async Task ConfirmForget()
    {
        showForgetModal = false;
        await Auth.ForgetUsernameAndLogoutAsync();
        Navigation.NavigateToRelative("login");
    }

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        await ChatService.DisposeAsync();
        await ActiveChannels.ClearAsync();
        Navigation.NavigateToRelative("login");
    }
}
