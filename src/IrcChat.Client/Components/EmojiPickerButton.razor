                       "😡", "😠", "🤬", "😷", "🤒", "🤕", "🤢", "🤮", "🥴", "😇"],
        ["Gestes"] = ["👍", "👎", "👊", "✊", "🤛", "🤜", "🤞", "✌️", "🤟", "🤘",
                      "👌", "🤏", "👈", "👉", "👆", "👇", "☝️", "✋", "🤚", "🖐️",
                      "🖖", "👋", "🤙", "💪", "🦾", "🤝", "🙌", "👐", "🤲", "🙏",
                      "✍️", "💅", "🤳", "💃", "🕺", "👏", "🫶", "🫂"],
