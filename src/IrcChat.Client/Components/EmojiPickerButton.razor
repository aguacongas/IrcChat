    private async Task TogglePicker()
    {
        await OnToggle.InvokeAsync(MessageId);
    }

    private async Task SelectEmoji(string emoji)
    {
        // Fermer le picker via le parent
        await OnToggle.InvokeAsync(MessageId);
        await OnReact.InvokeAsync(emoji);
    }

    private void SelectCategory(string category)
    {
        selectedCategory = category;
    }

    private string[] GetCurrentCategoryEmojis()
        => EmojiCategories.TryGetValue(selectedCategory, out var emojis) ? emojis : [];
}
