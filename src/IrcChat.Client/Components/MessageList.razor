@using IrcChat.Client.Extensions
@using IrcChat.Shared.Models
@using System.Diagnostics.CodeAnalysis
@using System.Text.RegularExpressions
@inject IJSRuntime JSRuntime
@inject ILogger<MessageList> Logger
@implements IAsyncDisposable

@if (ShowDescription)
{
    <div class="channel-description-header @(isHeaderCollapsed ? "collapsed" : "expanded")"
         @onclick="ToggleHeaderExpand">
        <div class="description-header-content">
            @if (!string.IsNullOrEmpty(ChannelDescription))
            {
                <div class="description-text">
                    @foreach (var line in ChannelDescription.Split('\n'))
                    {
                        @line
                        <br />
                    }
                </div>
            }
            else
            {
                <div class="description-text empty">
                    <em>Aucune description</em>
                </div>
            }
            @if (CanManage)
            {
                <button class="edit-description-btn"
                        @onclick="HandleEditClick"
                        @onclick:stopPropagation="true"
                        title="Modifier la description">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                    </svg>
                </button>
            }
        </div>
    </div>
}

<div class="messages" @ref="messagesContainer" @onclick="CloseAllPickers">
    @foreach (var item in Messages)
    {
        if (item is EphemeralPhotoDto photo)
        {
            <div class="message @(photo.SenderUsername == CurrentUsername ? "own" : string.Empty) message-photo">
                <div class="message-header-inline">
                    <span class="username" @onclick="() => OnUsernameClick(photo.SenderUsername)">@photo.SenderUsername</span>
                    <span class="time">@photo.Timestamp.ToLocalTime().ToMessageTimeString()</span>
                    <div class="photo-content-inline" @onclick="() => HandlePhotoClick(photo)">
                        <div class="photo-thumbnail-inline">
                            <img src="@photo.ThumbnailUrl" alt="Photo éphémère" class="thumbnail-img" />
                        </div>
                        <div class="photo-info-inline">
                            <span class="photo-badge">📷 Photo éphémère</span>
                            @if (photo.ImageUrl != null)
                            {
                                <span class="photo-hint">Cliquer pour voir (3s)</span>
                            }
                        </div>
                    </div>
                    @if (CanManage)
                    {
                        <button class="btn-delete-message"
                                @onclick="() => OnDeleteMessage.InvokeAsync(photo.Id)"
                                title="Supprimer ce message">
                            🗑️
                        </button>
                    }
                </div>
            </div>
        }
        if (item is Message msg)
        {
            var isMentioned = IsMentioned(msg.Content, CurrentUsername);
            <div class="message @(msg.Username == CurrentUsername ? "own" : string.Empty) @(isMentioned ? "mentioned" : string.Empty)">
                <span class="username" @onclick="() => OnUsernameClick(msg.Username)">@msg.Username</span>
                <span class="time">@msg.Timestamp.ToLocalTime().ToMessageTimeString()</span>
                <span class="content">@((MarkupString)HighlightMention(msg.Content, CurrentUsername))</span>

                @* Badges de réactions existantes — sous le contenu du message *@
                @if (ShowReactions && msg.Reactions.Count > 0)
                {
                    <div class="reactions-list">
                        @foreach (var reaction in msg.Reactions)
                        {
                            var isOwn = reaction.UserIds.Contains(CurrentUserId);
                            var tooltip = string.Join(", ", reaction.Usernames);
                            <button class="reaction-badge @(isOwn ? "own" : string.Empty)"
                                    @onclick="() => OnReact.InvokeAsync((msg.Id, reaction.Emoji))"
                                    title="@tooltip"
                                    aria-label="@reaction.Emoji @reaction.Count réactions">
                                <span class="reaction-emoji">@reaction.Emoji</span>
                                <span class="reaction-count">@reaction.Count</span>
                            </button>
                        }
                    </div>
                }

                @* Boutons d'action : 😊 (picker) + 🗑️ (suppression) sur la même ligne en haut à droite *@
                @if (ShowReactions || CanManage)
                {
                    <div class="message-actions">
                        @if (ShowReactions)
                        {
                            <EmojiPickerButton MessageId="@msg.Id"
                                               IsOpen="@(openPickerMessageId == msg.Id)"
                                               OnToggle="@(id => HandlePickerToggle(id))"
                                               OnReact="@(emoji => OnReact.InvokeAsync((msg.Id, emoji)))" />
                        }
                        @if (CanManage)
                        {
                            <button class="btn-delete-message"
                                    @onclick="() => OnDeleteMessage.InvokeAsync(msg.Id)"
                                    title="Supprimer ce message">
                                🗑️
                            </button>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

<EphemeralPhotoModal Photo="@selectedPhoto" OnClose="HandleModalClose" />

@code {
    private bool isHeaderCollapsed = false;
    private ElementReference messagesContainer;
    private IJSObjectReference? scrollModule;
    private int previousMessageCount = 0;
    private bool isUserScrolling = false;
    private DotNetObjectReference<MessageList>? dotNetReference;
    private List<IMessage> messages = new();
    private EphemeralPhotoDto? selectedPhoto;

    // Id du picker actuellement ouvert (null = tous fermés)
    private Guid? openPickerMessageId = null;

    private void HandlePickerToggle(Guid messageId)
    {
        // Si le picker cliqué est déjà ouvert → fermer, sinon ouvrir celui-là
        openPickerMessageId = openPickerMessageId == messageId ? null : messageId;
    }

    private void CloseAllPickers()
    {
        openPickerMessageId = null;
    }

    [Parameter]
    [SuppressMessage("Blazor", "BL0007", Justification = "Reset previous message count on set")]
    public List<IMessage> Messages
    {
        get => messages;
        set
        {
            messages = value;
            previousMessageCount = 0;
        }
    }

    [Parameter]
    public string CurrentUsername { get; set; } = string.Empty;

    [Parameter]
    public string CurrentUserId { get; set; } = string.Empty;

    [Parameter]
    public string? ChannelDescription { get; set; }

    [Parameter]
    public bool ShowDescription { get; set; }

    [Parameter]
    public bool CanManage { get; set; }

    /// <summary>
    /// Active l'affichage des réactions (salons publics uniquement).
    /// </summary>
    [Parameter]
    public bool ShowReactions { get; set; }

    [Parameter]
    public EventCallback OnEditDescription { get; set; }

    [Parameter]
    public EventCallback<string> OnUsernameClicked { get; set; }

    [Parameter]
    public EventCallback<Guid> OnDeleteMessage { get; set; }

    /// <summary>
    /// Événement levé quand l'utilisateur sélectionne un emoji pour un message.
    /// Paramètres : (messageId, emoji).
    /// </summary>
    [Parameter]
    public EventCallback<(Guid MessageId, string Emoji)> OnReact { get; set; }

    private async Task OnUsernameClick(string username)
    {
        if (username == CurrentUsername)
        {
            return;
        }

        await OnUsernameClicked.InvokeAsync(username);
    }

    private static bool IsMentioned(string content, string username)
    {
        if (string.IsNullOrEmpty(username) || string.IsNullOrEmpty(content))
        {
            return false;
        }

        return content.Contains(username, StringComparison.OrdinalIgnoreCase);
    }

    private static string HighlightMention(string content, string username)
    {
        if (string.IsNullOrEmpty(username) || string.IsNullOrEmpty(content))
        {
            return System.Net.WebUtility.HtmlEncode(content);
        }

        var escapedContent = System.Net.WebUtility.HtmlEncode(content);
        var escapedUsername = System.Text.RegularExpressions.Regex.Escape(username);

        var pattern = $@"\b({escapedUsername})\b";
        var regex = new Regex(pattern, RegexOptions.IgnoreCase, TimeSpan.FromSeconds(1));

        return regex.Replace(escapedContent,
            match => $"<span class=\"mention-highlight\">{match.Value}</span>");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                scrollModule = await JSRuntime.InvokeAsync<IJSObjectReference>(
                    "import", "./js/scroll-helper.js");

                dotNetReference = DotNetObjectReference.Create(this);

                await scrollModule.InvokeVoidAsync("attachScrollListener",
                    messagesContainer,
                    dotNetReference);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Erreur lors du chargement du module de scroll.");
            }
        }

        if (Messages.Count > previousMessageCount)
        {
            previousMessageCount = Messages.Count;

            if (!isUserScrolling)
            {
                await ScrollToBottomAsync();
            }
        }
    }

    private async Task ScrollToBottomAsync()
    {
        if (scrollModule != null)
        {
            try
            {
                await scrollModule.InvokeVoidAsync("scrollToBottom", messagesContainer);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Erreur lors de l'appel scroll to bottom.");
            }
        }
    }

    private Task HandleEditClick()
        => OnEditDescription.InvokeAsync();

    [JSInvokable]
    public void OnUserScroll(bool isAtBottom)
    {
        isUserScrolling = !isAtBottom;
    }

    [JSInvokable]
    public void OnScrollPositionChanged(bool shouldCollapse)
    {
        if (isHeaderCollapsed != shouldCollapse)
        {
            isHeaderCollapsed = shouldCollapse;
            InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleHeaderExpand()
    {
        isHeaderCollapsed = !isHeaderCollapsed;
    }

    private void HandlePhotoClick(EphemeralPhotoDto photo)
    {
        selectedPhoto = photo;
        StateHasChanged();
    }

    private void HandleModalClose()
    {
        selectedPhoto = null;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (scrollModule != null)
        {
            try
            {
                await scrollModule.DisposeAsync();
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Erreur lors de la libération du module de scroll.");
            }
        }

        dotNetReference?.Dispose();

        GC.SuppressFinalize(this);
    }
}
